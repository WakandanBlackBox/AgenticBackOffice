{
  "name": "backoffice-agent",
  "version": "0.1.0",
  "type": "module",
  "description": "AI-powered back-office platform for freelancers and agencies",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "node --env-file=.env --watch server/index.js",
    "dev:client": "vite",
    "build": "vite build",
    "start": "node server/index.js",
    "db:migrate": "node --env-file=.env server/migrate.js",
    "db:seed": "node --env-file=.env server/seed.js",
    "postinstall": "npm run build"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "express-rate-limit": "^8.3.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.5.2",
    "concurrently": "^9.1.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "vite": "^6.3.0"
  }
}
